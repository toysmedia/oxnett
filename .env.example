APP_NAME=OxNet
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://oxnet.co.ke
APP_DOMAIN=oxnet.co.ke

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# System Database (main — stores tenants, pricing plans, super admins, etc.)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=oxnet_system
DB_USERNAME=root
DB_PASSWORD=

# Tenant DB Root (used only for DDL: CREATE/DROP tenant databases and users)
TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=3306
TENANT_DB_ROOT_USERNAME=root
TENANT_DB_ROOT_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@oxnet.co.ke"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

IS_DEMO=0
VERSION=2.0

# RADIUS (system-level default; tenants can override via tenant settings)
RADIUS_SERVER_IP=127.0.0.1
RADIUS_SECRET=
ROUTER_CALLBACK_SECRET=

# Super Admin M-Pesa (for collecting tenant subscription payments)
SA_MPESA_ENV=sandbox
SA_MPESA_CONSUMER_KEY=
SA_MPESA_CONSUMER_SECRET=
SA_MPESA_SHORTCODE=174379
SA_MPESA_PASSKEY=
SA_MPESA_CALLBACK_URL=https://oxnet.co.ke/api/mpesa/subscription-callback

# Encryption key for tenant credentials stored in system DB (AES-256)
# Generate with: php artisan key:generate --show
TENANT_ENCRYPTION_KEY=

# OpenAI (for AI Assistant — Phase 6)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Management IPs (comma-separated, for router callback IP allowlist)
MANAGEMENT_IPS=

# Africa's Talking SMS (system-level; tenants use their own credentials via tenant_settings)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=
AT_ENV=sandbox
SMS_DRIVER=africastalking
